{
    "app-id": "tech.livingonlinux.gnostr",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "gnostr",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--talk-name=org.freedesktop.secrets",
        "--env=PYTHONPATH=/app/lib/python3.12/site-packages"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "build-options": {
        "env": {
            "CFLAGS": "",
            "CXXFLAGS": "",
            "LDFLAGS": ""
        }
    },
    "modules": [
