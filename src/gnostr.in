import os
import sys
import signal
import locale
import gettext
import glob

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

# --- SMART PATH DETECTION ---
# Automatically find site-packages in /app/lib OR /app/lib64.
# This handles the architecture differences cleanly at runtime.
site_packages = glob.glob('/app/lib*/python*/site-packages')
for path in site_packages:
    if path not in sys.path:
        sys.path.insert(0, path)

# Add the 'gnostr' application source
sys.path.insert(1, pkgdatadir)
# ----------------------------

signal.signal(signal.SIGINT, signal.SIG_DFL)
locale.bindtextdomain('gnostr', localedir)
locale.textdomain('gnostr')
gettext.install('gnostr', localedir)

if __name__ == '__main__':
    import gi
    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'gnostr.gresource'))
    resource._register()

    from gnostr.main import main
    sys.exit(main(VERSION))
